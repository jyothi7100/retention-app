{
  "xsappname": "retention-app",
  "tenant-mode": "dedicated",
  "description": "Security profile of called application",
  "scopes": [
    {
      "name": "uaa.user",
      "description": "UAA"
    },
    {
      "name": "$XSAPPNAME.SupplierUser",
      "description": "Supplier Access"
    }
  ],
  "role-templates": [
    {
      "name": "Token_Exchange",
      "description": "UAA",
      "scope-references": ["uaa.user"]
    },
    {
      "name": "SupplierRoleV2",
      "description": "Dynamically filters data by ANID",
      "scope-references": ["$XSAPPNAME.SupplierUser"],
      "attribute-references": ["anid"]
    }
],
  "attributes": [
  {
    "name": "anid",
    "description": "Ariba Network ID",
    "valueType": "string",
    "valueRequired": false
  }
],
  "oauth2-configuration": {
    "redirect-uris": [
      "https://*.us10-001.hana.ondemand.com/**",
      "https://*.ae01.hana.ondemand.com/**"
    ]
  }
}