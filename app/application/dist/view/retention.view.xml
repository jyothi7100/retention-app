<mvc:View controllerName="application.controller.retention"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:u="sap.ui.unified"
    xmlns:core="sap.ui.core"
    xmlns="sap.m">
  <Page id="page" >

  <customHeader>
    <Bar id="_IDGenBar1">
      <contentLeft>
        <Title id="_IDGenTitle3" text="Retention Platform" level="H4"/>
       
      </contentLeft>
      <contentRight>
      <Text id="_IDGenLoggedInAsText" text="{loggedInUser>/displayText}" class="sapUiTinyMarginTop"/>
        <Image id="_IDGenImage"
          src="{ value: 'application/images/logo.png', formatter: 'sap.ui.require.toUrl' }"
          height="45px"
          densityAware="false"
          class="sapUiSmallMarginEnd"/>
           
      </contentRight>
    </Bar>
  </customHeader>
    <VBox id="_IDGenVBox" class="sapUiSmallMargin">

      <HBox id="_IDGenHBox" justifyContent="SpaceAround" class="sapUiSmallMarginBottom">

        <GenericTile id="_IDGenGenericTile" header="All" subheader="Total Records" press="onTilePress" tooltip=" ">
          <TileContent id="_IDGenTileContent">
            <NumericContent id="_IDGenNumericContent" value="{kpi>/AllCount}" icon="sap-icon://database" valueColor="Neutral" tooltip=" "/>
          </TileContent>
        </GenericTile>

        <GenericTile id="_IDGenGenericTile1" header="Retained" subheader="Retention Due" press="onTilePress" tooltip=" ">
          <TileContent id="_IDGenTileContent1">
            <NumericContent id="_IDGenNumericContent1" value="{kpi>/RetainedCount}" icon="sap-icon://locked" valueColor="Critical" tooltip=" "/>
          </TileContent>
        </GenericTile>

        <GenericTile id="_IDGenGenericTile2" header="Due for Refund" subheader="Pending Refunds" press="onTilePress" tooltip=" ">
          <TileContent id="_IDGenTileContent2">
            <NumericContent id="_IDGenNumericContent2" value="{kpi>/RefundCount}" icon="sap-icon://payment-approval" valueColor="Critical" tooltip=" "/>
          </TileContent>
        </GenericTile>

        <GenericTile id="_IDGenGenericTile3" header="Request In Progress" subheader="Workflow Running" press="onTilePress" tooltip=" ">
          <TileContent id="_IDGenTileContent3">
            <NumericContent id="_IDGenNumericContent3" value="{kpi>/ProgressCount}" icon="sap-icon://process" valueColor="Neutral" tooltip=" "/>
          </TileContent>
        </GenericTile>

        <GenericTile id="_IDGenGenericTile4" header=" Request Approved" subheader="Completed" press="onTilePress" tooltip=" ">
          <TileContent id="_IDGenTileContent4">
            <NumericContent id="_IDGenNumericContent4" value="{kpi>/ApprovedCount}" icon="sap-icon://accept" valueColor="Good" tooltip=" "/>
          </TileContent>
        </GenericTile>

        <GenericTile id="_IDGenGenericTile5" header="Rejected" subheader="Declined" press="onTilePress" tooltip=" ">
          <TileContent id="_IDGenTileContent5">
            <NumericContent id="_IDGenNumericContent5" value="{kpi>/RejectedCount}" icon="sap-icon://decline" valueColor="Error" tooltip=" "/>
          </TileContent>
        </GenericTile>

        <GenericTile id="_IDGenGenericTile6" header="Paid" subheader="Payment Cleared" press="onTilePress" tooltip=" ">
          <TileContent id="_IDGenTileContent6">
            <NumericContent id="_IDGenNumericContent6" value="{kpi>/PaidCount}" icon="sap-icon://money-bills" valueColor="Good" tooltip=" "/>
          </TileContent>
        </GenericTile>

      </HBox>

      <Table id="retTable" items="{retentionList>/records}" mode="MultiSelect" multiSelectMode="ClearAll" selectionChange="onSelectionChange">
        <headerToolbar>
          <Toolbar id="_IDGenToolbar">
            <ToolbarSpacer id="_IDGenToolbarSpacer"/>
            <Button id="_IDGenSubmitClaimButton" text="Select for Claim" type="Emphasized" press="onSubmitClaim"/>
          </Toolbar>
        </headerToolbar>
        <columns>
          <Column id="_IDGenColumn1"><Text id="_IDGenText1" text="Invoice"/></Column>
          <Column id="_IDGenColumn2"><Text id="_IDGenText2" text="Description"/></Column>
          <Column id="_IDGenColumn3"><Text id="_IDGenText3" text="Invoice Date"/></Column>
          <Column id="_IDGenColumn4" hAlign="End"><Text id="_IDGenText4" text="Invoice Value"/></Column>
          <Column id="_IDGenColumn6" hAlign="End"><Text id="_IDGenText6" text="Retention Amount"/></Column>
          <Column id="_IDGenColumn7"><Text id="_IDGenText7" text="Due Date"/></Column>
          <Column id="_IDGenColumn8"><Text id="_IDGenText8" text="Status"/></Column>
          <Column id="_IDGenColumn9"><Text id="_IDGenText9" text="PO Number"/></Column>
          <!-- Added 2026-06-26 per user requirement: shows the
               sequential Claim ID (e.g. "RTAClaim-1") as a clickable
               link for any record that's been successfully submitted
               - blank for records with no claim. Text/press are both
               handled imperatively in the controller
               (formatClaimIdText / onClaimIdPress), since the
               Invoicenumber -> ClaimId lookup comes from a separate
               fetch (ClaimRecords), not a field on RetentionList
               itself - see _loadRetentionData. -->
          <Column id="_IDGenColumnClaimId" width="14rem"><Text id="_IDGenTextClaimId" text="Claim ID"/></Column>
        </columns>

        <items>
          <ColumnListItem id="_IDGenColumnListItem"
    type="{parts: ['retentionList>FinalStatus', 'retentionList>Invoicenumber'], formatter: '.formatRowSelectable'}">
            <cells>
              <Text id="_IDGenText11" text="{retentionList>Invoicenumber}"/>
              <Text id="_IDGenText12" text="{retentionList>Invoicedescription}"/>
              <Text id="_IDGenText13" text="{path: 'retentionList>Invoicedate', formatter: '.formatDate'}"/>
              <Text id="_IDGenText14" text="{parts: ['retentionList>Netamount', 'retentionList>Currency'], formatter: '.formatAmountWithCurrency'}"/>
              <Text id="_IDGenText16" textAlign="End" text="{parts: ['retentionList>Retentionamount', 'retentionList>Currency'], formatter: '.formatRetentionAmount'}"/>
              <Text id="_IDGenText17" text="{path: 'retentionList>Netduedate', formatter: '.formatDate'}"/>
              <ObjectStatus id="_IDGenObjectStatus1"
    text="{parts: ['retentionList>FinalStatus', 'retentionList>Invoicenumber'], formatter: '.formatStatusText'}"
    state="{parts: ['retentionList>FinalStatus', 'retentionList>Invoicenumber'], formatter: '.formatStatusState'}"
    tooltip=" "/>
              <Text id="_IDGenText18" text="{retentionList>Purchaseorder}"/>
              <Link id="_IDGenClaimIdLink"
    text="{path: 'retentionList>Invoicenumber', formatter: '.formatClaimIdText'}"
    tooltip="{path: 'retentionList>Invoicenumber', formatter: '.formatClaimIdText'}"
    visible="{path: 'retentionList>Invoicenumber', formatter: '.formatClaimIdVisible', targetType: 'any'}"
    press="onClaimIdPress"/>
            </cells>
          </ColumnListItem>
        </items>
      </Table>

    </VBox>
  </Page>
</mvc:View>